<header class="header">
  <h1>Pokédex</h1>

  <div class="d-flex gap-3 align-items-center flex-wrap">
    <%= link_to "Trainers", trainers_path, class: "btn btn-outline-primary btn-sm" %>
    <%= link_to "🎲 Random Pokémon", random_pokemons_path, class: "btn btn-outline-primary btn-sm" %>
  </div>

  <%# data-controller wires Stimulus, data-autocomplete-url-value tells it where to fetch %>
  <div data-controller="autocomplete"
       data-autocomplete-url-value="<%= autocomplete_pokemons_path %>"
       class="autocomplete-wrapper">

    <%= form_with url: root_path, method: :get do |f| %>
      <div class="input-group">
        <div class="form-floating">
          <%# data-autocomplete-target="input" — Stimulus finds this element %>
          <%# data-action — fires search() on every keystroke, close() on Escape %>
          <%= f.text_field :search,
                placeholder: "Jigglypuff",
                class: "form-control",
                value: params[:search],
                autocomplete: "off",
                data: {
                  autocomplete_target: "input",
                  action: "input->autocomplete#search keydown.esc->autocomplete#close"
                } %>
          <%= f.label :search, "Search for a Pokémon" %>
        </div>
        <%= f.submit "Search", class: "btn btn-primary" %>
      </div>
    <% end %>

    <%# data-autocomplete-target="results" — Stimulus renders results here %>
    <ul class="autocomplete-results d-none" data-autocomplete-target="results"></ul>

  </div>
</header>

<% if @pokemons.any? %>
  <div class="grid">
    <% @pokemons.each do |pokemon| %>
      <%= render pokemon %>
    <% end %>
  </div>
<% else %>
  <p class="text-secondary mt-4">
    No Pokémon found<% if params[:search].present? %> for "<%= params[:search] %>"<% end %>.
    Maybe we're not evolved enough 🙈
  </p>
<% end %>
